<template>
  <div class="ai-chat-page">
    <div class="page-header">
      <h1>🏠 搬家/装修规划助手</h1>
      <p class="subtitle">告诉我要搬家或装修，我来帮你规划一切</p>
    </div>
    <div class="quick-templates" v-if="messages.length === 0">
      <a-card title="🚀 快速开始">
        <a-space direction="vertical" style="width: 100%">
          <a-button block @click="useTemplate('我要从北京朝阳区搬家到海淀区，两室一厅，4月1日搬，预算5000')">📦 北京朝阳→海淀，两室一厅，4月1日，预算5000</a-button>
          <a-button block @click="useTemplate('新房装修，100平米三室两厅，现代简约风格，预算20万')">🏠 新房装修，100平米三室两厅，现代简约，预算20万</a-button>
          <a-button block @click="useTemplate('旧房翻新，两室一厅60平米，预算10万左右')">🔨 旧房翻新，两室一厅60平米，预算10万</a-button>
        </a-space>
      </a-card>
    </div>
    <div class="chat-container" ref="chatContainer">
      <div class="message-list">
        <div v-for="msg in messages" :key="msg.id" :class="['message', msg.role]">
          <div class="message-avatar"><a-avatar :size="36">{{ msg.role === 'user' ? '我' : '🤖' }}</a-avatar></div>
          <div class="message-content">
            <div class="message-header">
              <span>{{ msg.role === 'user' ? '你' : '规划助手' }}</span>
              <span class="time">{{ formatTime(msg.timestamp) }}</span>
            </div>
            <div v-if="msg.generated_checklist && msg.role === 'assistant'" class="plan-card">
              <a-card size="small" title="📋 已生成搬家清单">
                <a-descriptions :column="2" size="small">
                  <a-descriptions-item label="物品数">{{ msg.generated_checklist.items?.length || 0 }} 件</a-descriptions-item>
                  <a-descriptions-item label="箱数">{{ msg.generated_checklist.boxes?.length || 0 }} 箱</a-descriptions-item>
                  <a-descriptions-item label="预算">¥{{ msg.generated_checklist.cost || 0 }}</a-descriptions-item>
                </a-descriptions>
                <div style="margin-top: 12px"><a-button type="primary" size="small" @click="savePlan(msg)">保存到项目</a-button></div>
              </a-card>
            </div>
            <div v-if="msg.generated_plan && msg.role === 'assistant'" class="plan-card">
              <a-card size="small" title="🏠 已生成装修方案">
                <a-descriptions :column="2" size="small">
                  <a-descriptions-item label="户型">{{ msg.generated_plan.house_type }}</a-descriptions-item>
                  <a-descriptions-item label="面积">{{ msg.generated_plan.house_area }}㎡</a-descriptions-item>
                  <a-descriptions-item label="风格">{{ msg.generated_plan.style }}</a-descriptions-item>
                  <a-descriptions-item label="预算">¥{{ (msg.generated_plan.total_budget || 0).toLocaleString() }}</a-descriptions-item>
                </a-descriptions>
                <div style="margin-top: 12px"><a-button type="primary" size="small" @click="savePlan(msg)">保存到项目</a-button></div>
              </a-card>
            </div>
            <div class="message-body" v-html="renderMarkdown(msg.content)"></div>
            <div v-if="msg.suggested_actions?.length && msg.role === 'assistant'" class="suggested-actions">
              <span class="label">你可以：</span>
              <a-tag v-for="action in msg.suggested_actions" :key="action" @click="handleAction(action, msg)">{{ action }}</a-tag>
            </div>
          </div>
        </div>
        <div v-if="loading" class="message assistant">
          <div class="message-avatar"><a-avatar :size="36">🤖</a-avatar></div>
          <div class="message-content"><a-typography-paragraph class="typing"><a-spin size="small" /> 规划中...</a-typography-paragraph></div>
        </div>
      </div>
    </div>
    <div class="input-area">
      <a-textarea v-model="inputMessage" placeholder="描述你的需求..." :auto-size="{ minRows: 2, maxRows: 4 }" @press-enter="handleSend" />
      <div class="input-actions">
        <a-button @click="clearHistory">清空</a-button>
        <a-button type="primary" @click="handleSend" :disabled="!inputMessage.trim() || loading"><icon-send /> 发送</a-button>
      </div>
    </div>
  </div>
</template>

<script setup lang="ts">
import { ref, nextTick, onMounted } from 'vue'
import { Message } from '@arco-design/web-vue'
import { agentApi } from '../api/agent'

const inputMessage = ref('')
const messages = ref<any[]>([])
const loading = ref(false)
const chatContainer = ref<HTMLElement>()

const formatTime = (timestamp: string) => new Date(timestamp).toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit' })
onst renderMarkdown = (content: string) => content.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>').replace(/\n/g, '<br>')
const useTemplate = (template: string) => { inputMessage.value = template; handleSend() }

const handleSend = async () => {
  const content = inputMessage.value.trim()
  if (!content || loading.value) return
  messages.value.push({ id: Date.now().toString(), role: 'user', content, timestamp: new Date().toISOString() })
  inputMessage.value = ''; loading.value = true; scrollToBottom()
  try {
    const response = await agentApi.chat({ message: content })
    messages.value.push({ id: (Date.now() + 1).toString(), role: 'assistant', content: response.message,
      timestamp: new Date().toISOString(), project_type: response.project_type,
      generated_checklist: response.generated_checklist, generated_plan: response.generated_plan,
      suggested_actions: response.suggested_actions })
  } catch (error) { Message.error('发送失败，请重试') }
  finally { loading.value = false; scrollToBottom() }
}

const handleAction = (action: string, msg: any) => {
  if (action.includes('查看')) inputMessage.value = '详细展示一下'
  else if (action.includes('保存')) savePlan(msg)
}

const savePlan = async (msg: any) => {
  try {
    await agentApi.saveToProject({ project_id: null, create_new: true,
      generated_data: { ...msg.generated_checklist, ...msg.generated_plan, project_type: msg.project_type } })
    Message.success('已保存到项目')
  } catch (error) { Message.error('保存失败') }
}

const clearHistory = () => agentApi.clearHistory().then(() => { messages.value = [] })
const scrollToBottom = () => nextTick(() => { if (chatContainer.value) chatContainer.value.scrollTop = chatContainer.value.scrollHeight })
onMounted(() => agentApi.getHistory().then(res => { messages.value = res.messages; scrollToBottom() }))
</script>

